# Magic (magic.link) publishable key — powers sign in / sign up with Magic
# Embedded Wallets across the app. Get one from https://dashboard.magic.link
# (Settings → API Keys → Publishable key). Without this set, sign-in shows a
# friendly "not configured" error instead of crashing.
NEXT_PUBLIC_MAGIC_PUBLISHABLE_KEY=

# Particle Network project credentials — construct the buyer's Universal
# Account (EIP-7702 mode) used to read their real cross-chain balance.
# Get these from https://dashboard.particle.network (same three values the
# backend SDK's MorvaConfig.particle expects). Without all three set, the
# balance UI shows "Balance unavailable" instead of crashing.
NEXT_PUBLIC_PARTICLE_PROJECT_ID=
NEXT_PUBLIC_PARTICLE_CLIENT_KEY=
NEXT_PUBLIC_PARTICLE_APP_ID=
