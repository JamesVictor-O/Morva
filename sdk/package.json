{
  "name": "@morva/sdk",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "e2e": "tsx scripts/e2e-payment.ts"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "tsup": "^8.3.5",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@particle-network/universal-account-sdk": "2.0.3",
    "viem": "^2.54.2"
  }
}
