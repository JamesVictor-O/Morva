{
  "name": "@morva/sdk",
  "version": "0.1.0",
  "private": false,
  "description": "Headless TypeScript SDK for accepting crypto payments settled in a merchant's chosen token on Arbitrum One, from a buyer's cross-chain balance via Particle Universal Accounts (EIP-7702).",
  "keywords": [
    "crypto-payments",
    "web3",
    "eip-7702",
    "universal-account",
    "particle-network",
    "arbitrum",
    "checkout"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JamesVictor-O/Morva.git",
    "directory": "sdk"
  },
  "bugs": "https://github.com/JamesVictor-O/Morva/issues",
  "homepage": "https://github.com/JamesVictor-O/Morva/tree/main/sdk#readme",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "e2e": "tsx scripts/e2e-payment.ts",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "dotenv": "^17.4.2",
    "tsup": "^8.3.5",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@particle-network/universal-account-sdk": "2.0.3",
    "viem": "^2.54.2"
  }
}
